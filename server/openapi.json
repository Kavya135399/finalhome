{
  "openapi": "3.0.0",
  "info": {
    "title": "HomeSeva Pro REST API",
    "version": "1.0.0",
    "description": "Production-ready administrative backend endpoints for HomeSeva mobile application catalog and dashboard."
  },
  "servers": [
    {
      "url": "http://localhost:5000/api",
      "description": "Local API Server"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Authenticate User",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful, returns token and user payload"
          }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "Get all accounts",
        "responses": {
          "200": {
            "description": "Array of users"
          }
        }
      },
      "post": {
        "summary": "Create new account",
        "responses": {
          "200": {
            "description": "User created"
          }
        }
      }
    },
    "/services": {
      "get": {
        "summary": "Retrieve catalog services",
        "responses": {
          "200": {
            "description": "Service catalog lists"
          }
        }
      }
    }
  }
}
